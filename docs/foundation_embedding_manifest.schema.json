{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jkobject/TxGNN/schemas/foundation_embedding_manifest.schema.json",
  "title": "Jouvence KG foundation embedding run manifest",
  "type": "object",
  "required": [
    "task_id",
    "run_id",
    "created_at",
    "staged_only",
    "canonical_promotion",
    "kg_root",
    "output_dir",
    "policy_version",
    "models",
    "outputs",
    "validation",
    "environment"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^t_[0-9a-f]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "staged_only": {
      "type": "boolean",
      "const": true
    },
    "canonical_promotion": {
      "type": "boolean"
    },
    "kg_root": {
      "type": "string"
    },
    "output_dir": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "embedding_model",
          "embedding_version",
          "embedding_dim",
          "normalization"
        ],
        "properties": {
          "embedding_model": {
            "type": "string"
          },
          "embedding_version": {
            "type": "string"
          },
          "embedding_dim": {
            "type": "integer",
            "minimum": 1
          },
          "normalization": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "properties": {
        "node_text_embeddings": {
          "type": "object"
        },
        "edge_evidence_embeddings": {
          "type": "object"
        },
        "learned_fallback_config": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "blocked_modalities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "modality",
          "input",
          "reason"
        ],
        "properties": {
          "modality": {
            "type": "string"
          },
          "input": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "runtime_seconds": {
      "type": "number",
      "minimum": 0
    },
    "environment": {
      "type": "object"
    },
    "validation": {
      "type": "object",
      "required": [
        "passed"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        }
      }
    },
    "recompute_command": {
      "type": "string"
    },
    "summary_path": {
      "type": "string"
    }
  },
  "additionalProperties": true
}